# Google Gemini API key (required - get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_api_key_here

# Gemini model to use for responses
GEMINI_MODEL=gemini-3-flash

# Election metadata
ELECTION_COUNTRY=USA
ELECTION_YEAR=2024

# Google Cloud Platform configuration
GCP_PROJECT_ID=praveen-space              # Your GCP project ID
GCP_PROJECT_NUMBER=665822784067           # Your GCP project number
GCP_REGION=us-central1                    # Region for Cloud Run deployment
CLOUD_RUN_SERVICE_URL=                    # Deployed service URL (set after deployment)

# Firestore configuration
FIRESTORE_COLLECTION=chat_sessions        # Firestore collection for session data
